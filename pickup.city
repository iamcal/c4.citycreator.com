<?
	include("init.txt");

	list($id,$check) = explode('.',$c,2);

	if ($card_row = mysql_fetch_array(mysql_query("SELECT * FROM citycreator_cards WHERE id='$id' AND check='$check'",$db))){
			$city_row = get_city($card_row[city_id]);
			$city_id = $city_row[id];
	}else{
		header("location: no_card.city");
		exit;
	}

	$bg_row = mysql_fetch_array(mysql_query("SELECT * FROM citycreator_bgs WHERE order_id='$card_row[bg_id]' AND city_id='$city_id'",$db));
	if ($bg_row[bg_image]){
		$bg = "url(bgs/$city_id/$bg_row[bg_image])";
	}else{
		$bg = $bg_row[bg_color];
	}

	$pieces = array();
	$result = mysql_query("SELECT * FROM citycreator_pieces WHERE city_id='$city_id'",$db);
	while($row = mysql_fetch_array($result)){
		$pieces["$row[palette]_$row[id]"] = $row;
	}
?>
<html>
<head>
<title>City Creator - Pickup</title>
<style>

body		{ background-color: #ffffff; }
img		{ border: 0px; }
form		{ border: 0px; margin: 0px; padding: 0px; }

#outer		{ position: absolute; left:    50%; top:  20px; }
#canvas		{ position: absolute; left: -370px; top:  0px; width: 740px; height: 393px; z-index: 1; }
#canvasinner	{ position: absolute; left:    0px; top:   0px; width: 740px; height: 393px; z-index: 1; background-color: #cccccc; }

#borderleft	{ position: absolute; left:    0px; top:   0px; width: 257px; height: 393px; z-index: 15; }
#bordertop	{ position: absolute; left:  257px; top:   0px; width: 469px; height:  15px; z-index: 15; }
#borderbottom	{ position: absolute; left:  257px; top: 379px; width: 469px; height:  14px; z-index: 15; }
#borderright	{ position: absolute; left:  726px; top:   0px; width:  14px; height: 393px; z-index: 15; }
#board		{ position: absolute; left:  257px; top:  15px; width: 469px; height: 364px; z-index: 10; clip: rect(0px 469px 364px 0px); }

#textbox	{ position: absolute; left:   17px; top:  39px; width: 224px; height: 331px; z-index: 20; }

</style>
<script language="Javascript">
