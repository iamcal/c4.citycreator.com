	<div id="board" style="background: <?=$bg?>;">
<?
	foreach(explode(',',$card_row[pieces]) as $piece){
		list($palette, $id, $x, $y, $z) = explode('|',$piece);
		$piece = $pieces["${palette}_${id}"];
		echo "\t\t<div style=\"position: absolute; left: ${x}px; top: ${y}px; width: $piece[w]px; height: $piece[h]px; z-index: ${z};\"><img src=\"blocks/$city_id/$piece[image]\" width=\"$piece[w]\" height=\"$piece[h]\"></div>\n";
	}
?>
	</div>

	<div id="textbox" style="color: #ffffff; font-family: arial, helvetica, sans-serif; font-size: 11px; line-height: 13px;">
