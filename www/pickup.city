	<div id="pagebg"><img src="images/frame/main_home.gif" width="720" height="422" usemap="#topbarmap"></div>

	<div style="position: absolute; left: 259px; top: 8px; width: 29px; height: 17px;"><a href="./"          ><img src="images/frame/tab_home_off.gif"    width="29" height="17" border="0"></a></div>
	<div style="position: absolute; left: 290px; top: 8px; width: 46px; height: 17px;"><a href="members.city"><img src="images/frame/tab_members_off.gif" width="46" height="17" border="0"></a></div>
	<div style="position: absolute; left: 338px; top: 8px; width: 24px; height: 17px;"><a href="faq.city"    ><img src="images/frame/tab_faq_off.gif"     width="24" height="17" border="0"></a></div>
<?
	$left = 726;

	$ret = db_fetch("SELECT * FROM citycreator_cities ORDER BY id DESC");
	foreach ($ret['rows'] as $row){

		$left -= 3 + $row['tab_width'];
?>
	<div style="position: absolute; left: <?=$left?>px; top: 8px; width: <?=$row['tab_width']?>px; height: 17px;"><a href="build.city?city=<?=$row['id']?>"><img src="images/frame/tab_city_<?=$row['id']?>_off.gif" width="<?=$row['tab_width']?>" height="17" border="0"></a></div>
<?
	}
?>
	<div style="position: absolute; left: <?=($left-38)?>px; top: 8px; width: 35px; height: 16px;"><img src="images/frame/tab_label.gif" width="35" height="16"></div>

	<div id="welcome" class="text">
<? if ($card_row['message']){ ?>
		<?=htmlspecialchars($card_row['your_name'])?> (<?=htmlspecialchars($card_row['your_email'])?>) made you a city and sent you this message:<br>
		<br>
		<i><?=nl2br(trim(htmlspecialchars($card_row['message'])))?></i><br>
<? }else{ ?>
		<?=htmlspecialchars($card_row['your_name'])?> (<?=htmlspecialchars($card_row['your_email'])?>) made you a city!<br>
<? } ?>
		<br>
		If you'd like to print this card out, <a href="Javascript:print_city('<?=$_GET['c']?>');" style="color: #ffffff;">click here</a>.<br>
		<br>
		<img src="images/white.gif" width="224" height="1"><br>
		<br>
		You can create your very own city, and send it to your friends, by clicking the button below.<br>
		<br>
		<a href="./"><img src="images/btn_make.gif" width="101" height="16" border="0"></a>
	</div>

	<div id="board" style="background: <?=$bg?>;">
<?
	foreach(explode(',',$card_row['pieces']) as $piece){
		$bits = explode('|',$piece);
		if (count($bits) == 5){
			$piece = $pieces_index_2[$bits[0].'_'.$bits[1]];
			$x = $bits[2];
			$y = $bits[3];
			$z = $bits[4];
		}else{
			$piece = $pieces_index_1[$bits[0]];
			$x = $bits[1];
			$y = $bits[2];
			$z = $bits[3];
		}
		echo "\t\t<div style=\"position: absolute; left: ${x}px; top: ${y}px; width: $piece[w]px; height: $piece[h]px; z-index: ${z};\"><img src=\"blocks/$city_id/{$piece['image']}\" width=\"$piece[w]\" height=\"$piece[h]\"></div>\n";
	}
?>
	</div>

	<div id="bar"><a href="./"><img src="/images/pages/pickup_bar.gif" width="473" height="35" border="0"></a></div>

</div>
