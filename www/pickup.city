<?
	include('../include/init.php');

	$c = $_GET['c'] ?? '';
	list($id, $check) = array_pad(explode('.', $c, 2), 2, '');

	$card_row = db_single(db_fetch("SELECT * FROM citycreator_cards WHERE id=:id AND `check`=:check", array(
		'id'    => $id,
		'check' => $check,
	)));

	if (!isset($card_row['id']) || !$card_row['id']){
		header('location: no_card.city');
		exit;
	}

	$city_row = get_city($card_row['city_id'] ?? 0);
	$city_id = $city_row['id'] ?? 0;

	$bg_row = db_single(db_fetch("SELECT * FROM citycreator_bgs WHERE order_id=:order_id AND city_id=:city_id", array(
		'order_id' => $card_row['bg_id'] ?? 0,
		'city_id'  => $city_id,
	)));
	if (!empty($bg_row['bg_image'])){
		$bg = "url(bgs/".$bg_row['bg_image'].")";
	}else{
		$bg = $bg_row['bg_color'] ?? '#ffffff';
	}

	$pieces_index_1 = array();
	$pieces_index_2 = array();
	$ret = db_fetch("SELECT * FROM citycreator_pieces WHERE city_id=:city_id", array(
		'city_id' => $city_id,
	));
	foreach($ret['rows'] as $row){
		$pieces_index_1[$row['uid']] = $row;
		$pieces_index_2[$row['palette'].'_'.$row['id']] = $row;
	}
?>
