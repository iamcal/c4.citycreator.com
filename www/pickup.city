#copyright	{ position: absolute; left: -370px; top: 442px; width: 740px; height:  20px; z-index: 1; }

#bordertop	{ position: absolute; left:    0px; top:   0px; width: 740px; height:   8px; }
#borderbottom	{ position: absolute; left:    0px; top: 430px; width: 740px; height:   9px; }
#borderleft	{ position: absolute; left:    0px; top:   8px; width:  10px; height: 422px; }
#borderright	{ position: absolute; left:  730px; top:   8px; width:  10px; height: 422px; }
#pagebg		{ position: absolute; left:   10px; top:   8px; width: 720px; height: 422px; }

#welcome	{ position: absolute; left:   22px; top:  87px; width: 214px; height: 330px; z-index: 10; }
#board		{ position: absolute; left:  257px; top:  28px; width: 469px; height: 364px; z-index: 10; clip: rect(0px 469px 364px 0px); }
#bar		{ position: absolute; left:  255px; top: 392px; width: 473px; height:  35px; z-index: 10; }

