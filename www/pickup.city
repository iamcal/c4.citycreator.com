					<td><img src="images/pickup_left.gif" width="4" height="364"></td>
					<td>
			<div id="board" style="background: <?=$bg?>;">
<?
	foreach(explode(',', $card_row['pieces'] ?? '') as $piece){
		$bits = explode('|', $piece);
		if (count($bits) == 5){
			$piece_row = $pieces_index_2[$bits[0].'_'.$bits[1]] ?? null;
			$x = $bits[2];
			$y = $bits[3];
			$z = $bits[4];
		}else if (count($bits) == 4){
			$piece_row = $pieces_index_1[$bits[0]] ?? null;
			$x = $bits[1];
			$y = $bits[2];
			$z = $bits[3];
		}else{
			continue;
		}
		if (!$piece_row) continue;
		echo "\t\t\t\t<div style=\"position: absolute; left: {$x}px; top: {$y}px; width: {$piece_row['w']}px; height: {$piece_row['h']}px; z-index: {$z};\"><img src=\"blocks/{$piece_row['uid']}.gif\" width=\"{$piece_row['w']}\" height=\"{$piece_row['h']}\"></div>\n";
	}
?>
			</div>
					</td>
					<td><img src="images/pickup_right.gif" width="4" height="364"></td>
				</tr>
