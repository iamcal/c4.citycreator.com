<?
	function insert_vote_cell($id){
		global $cfg, $voted, $total;
		$row = mysql_fetch_array(mysql_query("SELECT * FROM $cfg[db_prefix]_votes WHERE id='$id'"));
		$percent = round(100 * $row[votes] / $total);
		$width = round(85 * $row[votes] / $total);
?>
<? if ($row[enabled]){ ?>
<? if ($voted){ ?>
			<td align="left">
				<img src="vote/pair_<?=$id?>.gif" width="117" height="68"><br>
				<img src="images/space.gif" width="117" height="6"><br>
				<table cellpadding="0" cellspacing="0" border="0">
					<tr>
						<td bgcolor="#C3E1AA"><img src="images/space.gif" width="<?=$width?>" height="10"></td>
						<td><img src="images/space.gif" width="4" height="10"></td>
						<td class="result"><?=$percent?>%</td>
					</tr>
				</table>
				<img src="images/space.gif" width="117" height="9"><br>
			</td>
<? }else{ ?>
			<td align="right">
				<img src="vote/pair_<?=$id?>.gif" width="117" height="68"><br>
				<img src="images/space.gif" width="117" height="5"><br>
				<a href="vote.city?vote=<?=$row[id]?>"><img src="images/vote_button.gif" width="24" height="20"></a><br>
			</td>
<? } ?>
<? }else{ ?>
			<td align="right">
				<img src="vote/grey_<?=$id?>.gif" width="117" height="68"><br>
				<img src="images/space.gif" width="117" height="5"><br>
				<img src="images/vote_in.gif" width="117" height="20"><br>
			</td>
<? } ?>
<? } ?>

