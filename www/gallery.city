<?
	include('include/init.txt');

	$title = 'Gallery';
	$nav = 'gallery';

	$perpage = 9;

	list($count) = mysql_fetch_array(mysql_query("SELECT COUNT(*) FROM $cfg[db_prefix]_gallery WHERE deleted=0"));
	$page = $page?round($page):1;
	$pages = ceil($count / $perpage);
	if ($page < 1){ $page = 1; }
	if ($page > $pages){ $page = $pages; }

	#
	# grab results
	#

	$start = ($page-1)*$perpage;
	$gallery_result = mysql_query("SELECT * FROM $cfg[db_prefix]_gallery WHERE deleted=0 ORDER BY date_create DESC LIMIT $start,$perpage");

	#
	# generate page markers
	#

	$markers = array();

	for($i=1; $i<=$pages; $i++){
		if ($i == $page){
			$markers[] = "<b>$i</b>";
		}else{
			$markers[] = "<a href=\"gallery.city?page=$i\">$i</a>";
		}
	}

	$markers = implode(' | ', $markers);


	include('include/page_top.txt');
?>

<script language="Javascript" src="gallery.js"></script>

	<img src="images/title_gallery.gif" width="61" height="12"><br>
