<? insert_cell(); ?>
			<td><img src="images/space.gif" width="23" height="157"></td>
<? insert_cell(); ?>
			<td><img src="images/space.gif" width="23" height="157"></td>
<? insert_cell(); ?>
		</tr>
		<tr><td colspan="5" bgcolor="#C3E1AA"><img src="images/space.gif" width="23" height="1"></td></tr>
		<tr><td colspan="5"><img src="images/space.gif" width="23" height="8"></td></tr>
		<tr><td colspan="5" class="text">Pages: <?=$markers?></td></tr>
		<tr><td colspan="5"><img src="images/space.gif" width="23" height="8"></td></tr>
		<tr><td colspan="5" bgcolor="#C3E1AA"><img src="images/space.gif" width="23" height="1"></td></tr>
	</table>


	

<?
	function insert_cell(){
		global $gallery_result;
		$row = mysql_fetch_array($gallery_result);
		if ($row[id]){
?>
			<td class="text">
				<a href="Javascript:gallery_pop(<?=$row[id]?>);"><img src="image.city?g=<?=$row[id]?>&mid=1" width="125" height="96"></a><br>
				<br>
<? if ($row[your_name]){ ?>
				By: <b><?=HtmlSpecialChars($row[your_name])?></b><br>
<? } ?>
<? if ($row[your_location]){ ?>
				From: <b><?=HtmlSpecialChars($row[your_location])?></b><br>
<? } ?>
			</td>
<?
		}else{
?>
			<td><img src="images/gallery_hold.gif" width="125" height="96"></td>
<?
		}
	}
?>



