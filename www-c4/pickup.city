<?
	foreach(explode(',',$card_row[pieces]) as $piece){
		$bits = explode('|',$piece);
		if (count($bits) == 5){
			$piece = $pieces_index_2[$bits[0].'_'.$bits[1]];
			$x = $bits[2];
			$y = $bits[3];
			$z = $bits[4];
		}else{
			$piece = $pieces_index_1[$bits[0]];
			$x = $bits[1];
			$y = $bits[2];
			$z = $bits[3];
		}
		echo "\t\t\t\t<div style=\"position: absolute; left: ${x}px; top: ${y}px; width: $piece[w]px; height: $piece[h]px; z-index: ${z};\"><img src=\"blocks/$piece[uid].gif\" width=\"$piece[w]\" height=\"$piece[h]\"></div>\n";
	}
