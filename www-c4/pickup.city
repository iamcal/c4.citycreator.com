<?
	include("include/init.txt");

	list($id,$check) = explode('.',$c,2);

	if ($card_row = mysql_fetch_array(mysql_query("SELECT * FROM $cfg[db_prefix]_cards WHERE id='$id' AND `check`='$check'",$db))){
			$city_row = get_city($card_row[city_id]);
			$city_id = $city_row[id];
	}else{
		header("location: no_card.city");
		exit;
	}

	$bg_row = mysql_fetch_array(mysql_query("SELECT * FROM $cfg[db_prefix]_bgs WHERE order_id='$card_row[bg_id]' AND city_id='$city_id'",$db));
	if ($bg_row[bg_image]){
		$bg = "url(bgs/$bg_row[bg_image])";
	}else{
		$bg = $bg_row[bg_color];
	}

	$pieces_index_1 = array();
	$pieces_index_2 = array();
	$result = mysql_query("SELECT * FROM $cfg[db_prefix]_pieces WHERE city_id='$city_id'",$db);
	while($row = mysql_fetch_array($result)){
		$pieces_index_1[$row[uid]] = $row;
		$pieces_index_2["$row[palette]_$row[id]"] = $row;
	}
?>
